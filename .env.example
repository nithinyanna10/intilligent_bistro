# ============================================================
# The Intelligent Bistro — environment example
# ============================================================
# Copy this file into apps/backend/.env and apps/mobile/.env
# (or just set the relevant subset in each app).
# ============================================================

# ---------- Backend ----------
PORT=4000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---------- Mobile ----------
# Use http://localhost:4000 for iOS simulator / Android emulator on macOS.
# On a physical device, replace localhost with your machine's LAN IP, e.g.
# EXPO_PUBLIC_API_URL=http://192.168.1.25:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
